# .env — liegt auf dem VPS unter /opt/hausfest26/.env
# Kopiere diese Datei zu ".env" und trage die Werte ein.

# Postgres (Pflicht)
POSTGRES_PASSWORD=bitte-ein-langes-zufaelliges-passwort

# Optional: eigener DB-Name/-User (Standard: hausfest26)
# POSTGRES_DB=hausfest26
# POSTGRES_USER=hausfest26

# Optional: KI-Beleglesung im Finanzen-Modul.
# Ohne Key funktioniert alles – Belege werden dann nur manuell erfasst.
# Key aus der Anthropic Console: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: anderes Modell für die Beleglesung (Standard: Haiku).
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Web-Push (Benachrichtigungen bei @Erwähnung / Todo-Zuweisung).
# Schlüssel einmalig erzeugen mit:  npx web-push generate-vapid-keys
# Ohne diese Werte sind Push-Benachrichtigungen einfach deaktiviert.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:orga@hausfest.al-daellen.ch
